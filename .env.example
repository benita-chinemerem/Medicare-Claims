# ============================================================
# fraud-anomaly-ai — Environment Configuration
# Copy this file to .env and fill in your values.
# The defaults below work for a local development run.
# ============================================================

# ---- Airflow -----------------------------------------------
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ---- PostgreSQL (fraud_claims analytics database) ----------
FRAUD_DB_HOST=postgres
FRAUD_DB_PORT=5432
FRAUD_DB_NAME=fraud_claims
FRAUD_DB_USER=airflow
FRAUD_DB_PASSWORD=airflow

# ---- Data paths (inside the container) ---------------------
# These map to ./data/ on your host via the Docker volume mount.
DATA_RAW_PATH=/opt/airflow/data/raw
DATA_PARQUET_PATH=/opt/airflow/data/parquet

# ---- Model storage -----------------------------------------
MODEL_PATH=/opt/airflow/models

# ---- Pipeline tuning ---------------------------------------
# contamination: expected fraction of anomalies in the data.
# 0.05 = top 5% of providers flagged by Isolation Forest.
CONTAMINATION_RATE=0.05

# risk_score_threshold: providers above this score appear in dashboard.
RISK_SCORE_THRESHOLD=75

# Weekly scoring DAG: how many claim rows to ingest per run.
WEEKLY_BATCH_SIZE=500000
